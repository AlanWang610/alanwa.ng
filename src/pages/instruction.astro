---
import BaseLayout from '../layouts/BaseLayout.astro';
import InstructionList from '../components/InstructionList.tsx';
import courses from '../data/instruction.json';
---

<BaseLayout
  title="Instruction — Sun & Steel"
  description="I believe in teaching as a passive act: recreating and facilitating discovery in a group setting."
  canonicalPath="/instruction/"
>
  <div class="page">
    <div class="container">
      <h1 class="page-title">Instruction</h1>
      <p class="page-intro">
        I believe in teaching as a passive act: recreating and facilitating discovery in a group setting is more effective than a defined end goal. Late night office hours in Quincy dining hall on the other hand...
      </p>

      <InstructionList courses={courses} client:load />
    </div>
  </div>
</BaseLayout>
