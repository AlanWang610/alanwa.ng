---
import BaseLayout from '../layouts/BaseLayout.astro';
import InstructionList from '../components/InstructionList.tsx';
import courses from '../data/instruction.json';
---

<BaseLayout
  title="Instruction — Sun & Steel"
  description="I believe that if learning should be active, effective teaching that recreates and facilitates discovery in a group setting is more effective than teaching that optimizes for coverage."
  canonicalPath="/instruction/"
>
  <div class="page">
    <div class="container">
      <h1 class="page-title">Instruction</h1>
      <p class="page-intro">
        I believe that if learning should be active, effective teaching that recreates and facilitates discovery in a group setting is more effective than teaching that optimizes for coverage. <a href="https://thedecisionlab.com/biases/hyperbolic-discounting" target="_blank" rel="noopener noreferrer">Late night office hours</a> in Quincy dining hall on the other hand...
      </p>

      <InstructionList courses={courses} client:load />
    </div>
  </div>
</BaseLayout>
