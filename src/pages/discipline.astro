---
import BaseLayout from '../layouts/BaseLayout.astro';
import DisciplineList from '../components/DisciplineList.tsx';
import workouts from '../data/workouts.json';

const allTags = [...new Set(workouts.flatMap((w) => w.tags))];
---

<BaseLayout
  title="Discipline — Sun & Steel"
  description="Training structured around distance running with supplementary strength work. Session record with external corroboration."
  canonicalPath="/discipline/"
>
  <div class="page">
    <div class="container">
      <h1 class="page-title">Discipline</h1>
      <p class="page-intro">
        I believe in cultivating the body daily through a combination of cardiovascular and strength training.
        Run and cycle more during the summer, swim and lift more during the winter.
        Here's a list of my favorite places to go to.
      </p>

      <DisciplineList workouts={workouts} tags={allTags} client:load />
    </div>
  </div>
</BaseLayout>
