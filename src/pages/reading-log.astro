---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import BookEntry from '../components/BookEntry.astro';
import readingLog from '../data/reading-log.json';

interface Book {
  title: string;
  author: string;
  note: string;
}

const completedYears: [string, Book[]][] = Object.entries(readingLog.completed)
  .sort(([a], [b]) => Number(b) - Number(a));
---

<BaseLayout
  title="Reading Log — Sun & Steel"
  description="Books completed and in progress. Short notes where the reading inflects current work or thinking."
  canonicalPath="/reading-log/"
>
  <div class="page">
    <div class="container">
      <h1 class="page-title">Reading Log</h1>
      <p class="page-intro">
        Books completed and in progress. Short notes where the reading inflects current work or thinking.
      </p>

      <div class="reading-section">
        <SectionHeading text="Now Reading" />
        {readingLog.current.map((book) => (
          <BookEntry
            title={book.title}
            author={book.author}
            note={book.note || undefined}
          />
        ))}
      </div>

      <div class="reading-section">
        <SectionHeading text="Completed" />
        {completedYears.map(([year, books]) => (
          <div>
            <div class="year-heading tnum">{year}</div>
            {books.map((book) => (
              <BookEntry
                title={book.title}
                author={book.author}
                note={book.note || undefined}
                completed
              />
            ))}
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
