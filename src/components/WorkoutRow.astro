---
interface Props {
  date: string;
  title: string;
  distance: string;
  duration: string;
  link: string;
  note?: string;
}

const { date, title, distance, duration, link, note } = Astro.props;
---

<div class="workout-row">
  <div class="workout-row__date tnum">{date}</div>
  <div>
    <div class="workout-row__title">{title}</div>
    {note && <div class="workout-row__note">{note}</div>}
    <a href={link} class="workout-row__link" target="_blank" rel="noopener noreferrer">
      MapMyRun
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left:4px;vertical-align:middle;">
        <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6" />
        <polyline points="15 3 21 3 21 9" />
        <line x1="10" y1="14" x2="21" y2="3" />
      </svg>
    </a>
  </div>
  <div class="workout-row__stats tnum">
    {distance !== '—' && <span>{distance}</span>}
    {distance !== '—' && <span style="margin:0 6px;color:var(--border);">&middot;</span>}
    <span>{duration}</span>
  </div>
</div>
