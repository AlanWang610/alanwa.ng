---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  href: string;
  featured?: boolean;
}

const { eyebrow, title, description, href, featured = false } = Astro.props;
---

<a href={href} class={`card ${featured ? 'card--featured' : ''}`}>
  <div class="card__eyebrow">{eyebrow}</div>
  <div class="card__title">{title}</div>
  <div class="card__desc">{description}</div>
</a>
