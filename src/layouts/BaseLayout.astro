---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalPath?: string;
}

const {
  title,
  description = 'Builder, practitioner, instructor. Clarity over ornament, constraint over flourish.',
  ogImage = '/og-default.png',
  canonicalPath,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonical = canonicalPath ? `${siteUrl}${canonicalPath}` : undefined;
const currentPath = new URL(Astro.request.url).pathname;
---

<!doctype html>
<html lang="en" data-theme="day">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    {canonical && <link rel="canonical" href={canonical} />}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link
      rel="preload"
      href="/fonts/source-han-serif-jp-400-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/source-han-serif-jp-700-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <script is:inline>
      (function () {
        var t = localStorage.getItem('theme');
        if (t !== 'day' && t !== 'night') t = 'day';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header currentPath={currentPath} />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
